{
  "name": "@iprep/mdocks",
  "version": "0.1.0",
  "description": "mDocks CLI - start the local documentation server",
  "homepage": "https://www.mdocks.dev/",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "modcs": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "dev:start": "tsx src/index.ts start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
