{
  "name": "@mdocs/cli",
  "version": "0.1.3",
  "description": "mDocs CLI — start the local documentation server",
  "type": "module",
  "bin": {
    "mdocs": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "dev:serve": "tsx src/index.ts serve",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mdocs/server": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
